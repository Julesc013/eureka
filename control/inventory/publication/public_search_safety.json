{
  "schema_version": "0.1.0",
  "safety_policy_id": "eureka-public-search-safety-abuse-guard-v0",
  "status": "local_runtime_guard_active",
  "stability": "experimental",
  "no_runtime_implemented": false,
  "local_public_search_runtime_implemented": true,
  "hosted_public_search_runtime_implemented": false,
  "no_public_search_live": true,
  "no_hosted_public_search_live": true,
  "first_allowed_mode": "local_index_only",
  "allowed_modes": [
    "local_index_only"
  ],
  "disabled_modes": [
    "live_probe",
    "live_federated",
    "arbitrary_url_fetch",
    "local_path_search",
    "upload_search",
    "download_or_install"
  ],
  "request_limits": {
    "max_query_length": 160,
    "min_query_length_after_trim": 1,
    "max_include_items": 8,
    "max_request_body_bytes": 8192,
    "request_method_v0": "GET",
    "post_json_status": "future",
    "json_body_equivalent_reserved": true,
    "caller_provided_index_roots_allowed": false,
    "caller_provided_store_roots_allowed": false,
    "caller_provided_urls_allowed": false,
    "caller_provided_uploads_allowed": false
  },
  "result_limits": {
    "default_result_limit": 10,
    "max_result_limit": 25,
    "max_checked_sources_v0": "controlled_local_index_only",
    "max_live_sources_v0": 0,
    "raw_source_payloads_allowed": false,
    "download_urls_allowed": false,
    "install_urls_allowed": false
  },
  "timeout_policy": {
    "max_runtime_ms_contract": 3000,
    "source_timeout_ms": null,
    "live_source_timeout_ms": 0,
    "timeout_error_code": "timeout",
    "notes": "This is a local runtime target. Local Public Search Runtime v0 validates bounded requests, but no production timeout middleware is added."
  },
  "forbidden_parameters": [
    "index_path",
    "store_root",
    "run_store_root",
    "task_store_root",
    "memory_store_root",
    "local_path",
    "path",
    "file_path",
    "directory",
    "root",
    "url",
    "fetch_url",
    "crawl_url",
    "source_url",
    "download",
    "install",
    "execute",
    "upload",
    "user_file",
    "source_credentials",
    "auth_token",
    "api_key",
    "live_probe",
    "live_source",
    "network",
    "arbitrary_source"
  ],
  "forbidden_behaviors": [
    "arbitrary_url_fetching",
    "live_external_source_fanout",
    "google_scraping",
    "internet_archive_live_calls",
    "wayback_live_calls",
    "github_live_calls",
    "package_registry_live_calls",
    "local_filesystem_search",
    "caller_provided_index_path",
    "caller_provided_store_root",
    "downloads",
    "installs",
    "executable_launch",
    "uploads",
    "account_or_session_requirement",
    "telemetry_by_default",
    "private_path_leakage",
    "credential_submission",
    "raw_source_payload_return",
    "unbounded_query_or_result_behavior"
  ],
  "required_error_codes": [
    "bad_request",
    "query_required",
    "query_too_long",
    "limit_too_large",
    "unsupported_mode",
    "unsupported_profile",
    "unsupported_include",
    "forbidden_parameter",
    "local_paths_forbidden",
    "downloads_disabled",
    "installs_disabled",
    "uploads_disabled",
    "live_probes_disabled",
    "live_backend_unavailable",
    "rate_limited",
    "timeout"
  ],
  "error_mapping": {
    "empty_query_after_trim": "query_required",
    "query_over_160_characters": "query_too_long",
    "limit_above_25": "limit_too_large",
    "unsupported_mode": "unsupported_mode",
    "unsupported_profile": "unsupported_profile",
    "unsupported_include": "unsupported_include",
    "forbidden_parameter_default": "forbidden_parameter",
    "local_path_or_root_parameter": "local_paths_forbidden",
    "download_parameter_or_action": "downloads_disabled",
    "install_or_execute_parameter_or_action": "installs_disabled",
    "upload_or_user_file_parameter": "uploads_disabled",
    "live_probe_or_live_source_parameter": "live_probes_disabled",
    "backend_required_but_unavailable": "live_backend_unavailable",
    "future_rate_limit_exceeded": "rate_limited",
    "runtime_timeout": "timeout",
    "malformed_request": "bad_request"
  },
  "logging_privacy_policy": {
    "telemetry_implemented": false,
    "telemetry_default": "off",
    "raw_query_logging_default": "disabled",
    "future_hosted_rehearsal_logging": "short_retention_sanitized_only_after_policy",
    "ip_retention": "future_review_required",
    "private_path_logging": "forbidden",
    "credential_logging": "forbidden",
    "user_agent_logging": "future_review_required",
    "aggregate_failure_metrics": "allowed_only_if_privacy_reviewed",
    "manual_observations": "human_entered_not_telemetry",
    "external_query_log_uploads_by_default": false,
    "notes": "Logs are not a product feature. This policy adds no telemetry, analytics, accounts, or logging runtime."
  },
  "telemetry_policy": {
    "implemented": false,
    "default_enabled": false,
    "analytics_enabled": false,
    "crash_report_uploads_enabled": false,
    "query_log_uploads_enabled": false,
    "future_opt_in_required": true
  },
  "rate_limit_policy": {
    "runtime_middleware_implemented": false,
    "required_before_public_exposure": true,
    "policy_status": "future_required",
    "minimum_future_controls": [
      "bounded requests per client or deployment policy",
      "bounded concurrent searches",
      "timeout enforcement",
      "operator-visible disabled state",
      "rate_limited error mapping"
    ],
    "notes": "This policy defines the requirement before hosted public exposure but adds no rate-limiting middleware."
  },
  "operator_controls": {
    "required_future_flags": {
      "EUREKA_PUBLIC_SEARCH_MODE": "local_index_only",
      "EUREKA_ALLOW_LIVE_PROBES": "0",
      "EUREKA_ALLOW_DOWNLOADS": "0",
      "EUREKA_ALLOW_INSTALLS": "0",
      "EUREKA_ALLOW_LOCAL_PATHS": "0",
      "EUREKA_ALLOW_USER_UPLOADS": "0",
      "EUREKA_ALLOW_TELEMETRY": "0",
      "EUREKA_MAX_QUERY_LEN": "160",
      "EUREKA_MAX_RESULTS": "25",
      "EUREKA_SEARCH_TIMEOUT_MS": "3000",
      "EUREKA_PUBLIC_SEARCH_ENABLED": "0",
      "EUREKA_OPERATOR_KILL_SWITCH": "1"
    },
    "kill_switch_required": true,
    "default_public_search_enabled": false,
    "local_prototype_routes_enabled": true,
    "hosted_public_search_enabled": false,
    "operator_override_policy": "future_review_required",
    "notes": "Flags are future runtime requirements only. No process manager or deployment provider config is added."
  },
  "public_alpha_defaults": {
    "compatible_with_public_alpha_safe_mode": true,
    "public_search_live": false,
    "local_prototype_routes_allowed": true,
    "hosted_public_search_live": false,
    "local_paths_allowed": false,
    "live_probes_allowed": false,
    "downloads_allowed": false,
    "installs_allowed": false,
    "uploads_allowed": false,
    "telemetry_allowed": false,
    "notes": "Public-alpha safe mode remains non-production and may expose local/prototype /api/v1 search only under local_index_only constraints."
  },
  "static_site_defaults": {
    "github_pages_static_only": true,
    "site_dist_static_artifact": true,
    "public_search_live": false,
    "search_form_added": true,
    "runtime_routes_added": true,
    "static_search_handoff_added": true,
    "hosted_form_enabled": false,
    "live_backend_required": false,
    "notes": "Static pages include a no-JS disabled search handoff for local/prototype instructions. They must not claim hosted public search exists."
  },
  "live_backend_dependency": {
    "contract": "control/inventory/publication/live_backend_handoff.json",
    "status": "future_required_for_hosted_runtime",
    "live_backend_implemented": false,
    "local_public_search_runtime_implemented": true,
    "live_backend_required_before_public_route": true,
    "notes": "The safety guard now constrains local/prototype /api/v1 runtime routes. It does not make hosted public search live."
  },
  "live_probe_dependency": {
    "contract": "control/inventory/publication/live_probe_gateway.json",
    "live_probe_allowed_in_v0": false,
    "live_probe_runtime_implemented": false,
    "notes": "Future live probes require separate explicit approval and must remain outside local_index_only v0."
  },
  "action_policy_dependency": {
    "contract": "control/inventory/publication/action_policy.json",
    "downloads_allowed": false,
    "installs_allowed": false,
    "execute_allowed": false,
    "uploads_allowed": false,
    "notes": "Public search result cards may show blocked/future-gated actions only."
  },
  "local_cache_privacy_dependency": {
    "contract": "control/inventory/publication/local_cache_privacy_policy.json",
    "private_cache_runtime_allowed": false,
    "private_file_ingestion_allowed": false,
    "telemetry_allowed": false,
    "notes": "Public search must not accept private local paths, credentials, user files, or telemetry by default."
  },
  "prerequisites_for_runtime": [
    "python scripts/validate_public_search_contract.py",
    "python scripts/validate_public_search_result_card_contract.py",
    "python scripts/validate_public_search_safety.py",
    "local index root is server-owned and not caller-provided",
    "no local path parameters accepted",
    "no live probes accepted",
    "no downloads, installs, execution, or uploads exposed",
    "stable error mapping implemented and tested",
    "HTML and JSON response behavior defined",
    "operator flags wired and default-disabled",
    "kill switch wired and tested",
    "logging/privacy posture accepted",
    "public-alpha smoke tests planned",
    "no production readiness or API stability claim"
  ],
  "runtime_readiness_checklist": "docs/operations/PUBLIC_SEARCH_RUNTIME_READINESS_CHECKLIST.md",
  "created_by_slice": "public_search_safety_abuse_guard_v0",
  "notes": [
    "Public Search Safety / Abuse Guard v0 is now enforced by Local Public Search Runtime v0 for local/prototype routes.",
    "It does not implement rate-limit middleware, auth, sessions, telemetry, logging runtime, live probes, downloads, installers, uploads, local path ingestion, or backend hosting.",
    "Hosted public search exposure remains blocked until the readiness checklist, operator controls, and rehearsal gates are satisfied."
  ]
}
