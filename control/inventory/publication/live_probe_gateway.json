  ],
  "manual_only_sources": [
    {
      "id": "google_web_search",
      "status": "manual_external_baseline",
      "live_probe_candidate": false,
      "notes": "Google remains a human-operated manual baseline path only. Eureka does not scrape Google or automate Google searches."
    }
  ],
  "prohibited_behaviors": [
    "live probe implementation",
    "network calls",
    "URL fetching",
    "downloads",
    "scraping",
    "bulk crawling",
    "arbitrary URL fetching",
    "private account data access",
    "user credential forwarding",
    "production readiness claims",
    "live probe availability claims"
  ],
  "response_envelope": {
    "ok": true,
    "source_id": "internet_archive_metadata",
    "probe_status": "disabled",
    "query": "example query",
    "results": [],
    "evidence_records": [],
    "notices": [
      "Live probes are disabled in this static/public-alpha build."
    ],
    "limits": {
      "max_total_results": 20,
      "max_results_per_source": 10,
      "source_timeout_ms": 5000
    }
  },
  "error_envelope_alignment": {
    "docs": "docs/reference/LIVE_BACKEND_ERROR_ENVELOPE.md",
    "required_error_codes": [
      "capability_disabled",
      "live_probes_disabled",
      "source_disabled",
      "source_timeout",
      "rate_limited",
      "bad_request"
    ]
  },
  "created_by_slice": "live_probe_gateway_contract_v0",
  "notes": [
    "This is a contract and policy layer only.",
    "No source adapter, live probe endpoint, URL fetch, crawler, scraper, or external API call is added.",
    "Public Search API Contract v0 uses local_index_only only; live probe mode is not implemented or accepted by the public search request schema.",
    "Internet Archive live probing remains future and disabled until explicit human review and implementation approval.",
    "Google remains manual-baseline only and is not a live probe source.",
    "Compatibility Surface Strategy v0 keeps live probe results out of static, lite, text, files, snapshot, relay, and native-client projections unless a later gated backend explicitly enables them."
  ]
}
