        "account/private data"
      ],
      "default_result_cap": 10,
      "default_timeout_ms": 5000,
      "cache_required": true,
      "evidence_required": true,
      "notes": "Future public release metadata candidate; no GitHub API calls are implemented."
    },
    {
      "id": "software_heritage_metadata",
      "status": "future_disabled",
      "live_supported_now": false,
      "requires_operator_enable": true,
      "allowed_modes": [
        "item_metadata",
        "availability_check"
      ],
      "forbidden_modes": [
        "downloads",
