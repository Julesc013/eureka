    "notes": "Local runtime examples are localhost/prototype instructions only and are not public deployment evidence."
  },
  "operator_configuration_required": {
    "hosted_backend": true,
    "github_pages_python_runtime": false,
    "provider_config_committed": false,
    "deployment_approved": false,
    "rate_limit_policy_required_before_public": true,
    "operator_signoff_required_before_public": true
  },
  "created_by_slice": "public_search_static_handoff_v0",
  "notes": [
    "Public Search Static Handoff v0 connects site/dist to Local Public Search Runtime v0 without deploying a backend.",
    "The static page is no-JS and honest when no hosted backend URL is configured.",
    "GitHub Pages remains static-only and does not run Python.",
    "Hosted public search remains unavailable until a later rehearsal/deployment milestone records real evidence.",
    "Live probes, downloads, installs, uploads, accounts, local path search, arbitrary URL fetch, scraping, crawling, and telemetry remain disabled."
  ]
