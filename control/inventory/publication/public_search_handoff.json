{
  "schema_version": "0.1.0",
  "handoff_id": "eureka-public-search-static-handoff-v0",
  "status": "implemented_static_handoff",
  "stability": "experimental",
  "static_artifact": "site/dist",
  "runtime_dependency": "local_public_search_runtime_v0",
  "hosted_backend_status": "unavailable",
  "default_backend_mode": "not_configured",
  "backend_url_policy": {
    "hosted_backend_url": null,
    "hosted_backend_url_configured": false,
    "hosted_backend_url_verified": false,
    "fake_hosted_urls_allowed": false,
    "local_runtime_url": "http://127.0.0.1:8080",
    "local_runtime_url_is_public_deployment": false,
    "operator_configuration_required": true,
    "notes": "No hosted backend URL is configured. Static pages may show local runtime examples only when clearly labeled local/prototype."
  },
  "form_policy": {
    "no_js_required": true,
    "hosted_form_enabled": false,
    "disabled_static_form_rendered": true,
    "form_action_when_unconfigured": "",
