{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/pages/comparison_page.v0.json",
  "title": "EurekaComparisonPageV0",
  "description": "Contract-only, evidence-first public comparison page shape. It defines future comparison pages without runtime routes, live source calls, winner claims without evidence, downloads, or index/cache/ledger mutation.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "comparison_page_id",
    "comparison_page_kind",
    "status",
    "created_by_tool",
    "comparison_identity",
    "comparison_type",
    "subjects",
    "criteria",
    "comparison_matrix",
    "identity_comparison",
    "version_state_release_comparison",
    "representation_member_comparison",
    "source_evidence_provenance_comparison",
    "compatibility_comparison",
    "rights_risk_action_comparison",
    "conflicts_and_disagreements",
    "absence_near_miss_gap_comparison",
    "result_card_object_source_projection",
    "api_projection",
    "static_projection",
    "privacy",
    "limitations",
    "no_winner_without_evidence_guarantees",
    "no_runtime_guarantees",
    "no_mutation_guarantees",
    "notes",
    "runtime_comparison_page_implemented",
    "persistent_comparison_page_store_implemented",
    "comparison_page_generated_from_live_source",
    "comparison_winner_claimed",
    "live_source_called",
    "external_calls_performed",
    "source_sync_worker_executed",
    "source_cache_mutated",
    "evidence_ledger_mutated",
    "candidate_index_mutated",
    "candidate_promotion_performed",
    "public_index_mutated",
    "local_index_mutated",
    "master_index_mutated",
    "downloads_enabled",
    "uploads_enabled",
    "installs_enabled",
    "execution_enabled",
    "arbitrary_url_fetch_enabled",
    "rights_clearance_claimed",
    "malware_safety_claimed",
    "source_trust_claimed",
    "telemetry_exported"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "comparison_page_id": {
      "type": "string",
      "minLength": 1
    },
    "comparison_page_kind": {
      "type": "string",
      "const": "comparison_page"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft_example",
        "dry_run_validated",
        "synthetic_example",
        "public_safe_example",
        "fixture_comparison",
        "recorded_fixture_comparison",
        "candidate_comparison",
        "conflicted_comparison",
        "runtime_future",
        "rejected_by_policy"
      ]
    },
    "created_by_tool": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "comparison_identity": {
      "$ref": "#/$defs/comparison_identity"
    },
    "comparison_type": {
      "$ref": "#/$defs/comparison_type"
    },
    "subjects": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/subject"
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/criterion"
      }
    },
    "comparison_matrix": {
      "$ref": "#/$defs/comparison_matrix"
    },
    "identity_comparison": {
      "$ref": "#/$defs/identity_comparison"
    },
    "version_state_release_comparison": {
      "$ref": "#/$defs/version_state_release_comparison"
    },
    "representation_member_comparison": {
      "$ref": "#/$defs/representation_member_comparison"
    },
    "source_evidence_provenance_comparison": {
      "$ref": "#/$defs/source_evidence_provenance_comparison"
    },
    "compatibility_comparison": {
      "$ref": "#/$defs/compatibility_comparison"
    },
    "rights_risk_action_comparison": {
      "$ref": "#/$defs/rights_risk_action_comparison"
    },
    "conflicts_and_disagreements": {
      "$ref": "#/$defs/conflicts_and_disagreements"
    },
    "absence_near_miss_gap_comparison": {
      "$ref": "#/$defs/absence_near_miss_gap_comparison"
    },
    "result_card_object_source_projection": {
      "$ref": "#/$defs/result_card_object_source_projection"
    },
    "api_projection": {
      "$ref": "#/$defs/api_projection"
    },
    "static_projection": {
      "$ref": "#/$defs/static_projection"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "no_winner_without_evidence_guarantees": {
      "type": "object"
    },
    "no_runtime_guarantees": {
      "type": "object"
    },
    "no_mutation_guarantees": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_comparison_page_implemented": {
      "type": "boolean",
      "const": false
    },
    "persistent_comparison_page_store_implemented": {
      "type": "boolean",
      "const": false
    },
    "comparison_page_generated_from_live_source": {
      "type": "boolean",
      "const": false
    },
    "comparison_winner_claimed": {
      "type": "boolean",
      "const": false
    },
    "live_source_called": {
      "type": "boolean",
      "const": false
    },
    "external_calls_performed": {
      "type": "boolean",
      "const": false
    },
    "source_sync_worker_executed": {
      "type": "boolean",
      "const": false
    },
    "source_cache_mutated": {
      "type": "boolean",
      "const": false
    },
    "evidence_ledger_mutated": {
      "type": "boolean",
      "const": false
    },
    "candidate_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "candidate_promotion_performed": {
      "type": "boolean",
      "const": false
    },
    "public_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "local_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "master_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "downloads_enabled": {
      "type": "boolean",
      "const": false
    },
    "uploads_enabled": {
      "type": "boolean",
      "const": false
    },
    "installs_enabled": {
      "type": "boolean",
      "const": false
    },
    "execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "arbitrary_url_fetch_enabled": {
      "type": "boolean",
      "const": false
    },
    "rights_clearance_claimed": {
      "type": "boolean",
      "const": false
    },
    "malware_safety_claimed": {
      "type": "boolean",
      "const": false
    },
    "source_trust_claimed": {
      "type": "boolean",
      "const": false
    },
    "telemetry_exported": {
      "type": "boolean",
      "const": false
    }
