  "$defs": {
    "comparison_identity": {
      "type": "object",
      "required": [
        "comparison_id",
        "canonical_label",
        "comparison_scope",
        "comparison_basis",
        "limitations"
      ],
      "properties": {
        "comparison_id": {
          "type": "string"
        },
        "canonical_label": {
          "type": "string"
        },
        "comparison_scope": {
          "type": "string",
          "enum": [
            "object_to_object",
            "version_to_version",
            "source_to_source",
            "representation_to_representation",
            "compatibility_claims",
            "evidence_to_evidence",
            "candidate_to_candidate",
            "near_miss_to_result",
            "mixed",
            "unknown"
          ]
        },
        "comparison_basis": {
          "type": "string",
          "enum": [
            "synthetic_example",
            "fixture_backed",
            "recorded_fixture_backed",
            "public_index_future",
            "source_cache_future",
            "evidence_ledger_future",
            "candidate_index_future",
            "manual_review_future",
            "unknown"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "comparison_type": {
      "type": "object",
      "required": [
        "type",
        "comparison_goal",
        "winner_allowed",
        "scoped_recommendation_allowed",
        "limitations"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "object_identity_comparison",
            "version_comparison",
            "source_coverage_comparison",
            "representation_comparison",
            "member_comparison",
            "compatibility_comparison",
            "evidence_strength_comparison",
            "provenance_comparison",
            "rights_risk_action_comparison",
            "conflict_comparison",
            "absence_near_miss_comparison",
            "candidate_review_comparison",
            "unknown"
          ]
        },
        "comparison_goal": {
          "type": "string",
          "enum": [
            "explain_same_or_different",
            "choose_review_priority",
            "explain_conflict",
            "explain_source_coverage",
            "explain_compatibility",
            "explain_safe_action",
            "explain_absence",
            "unknown"
          ]
        },
        "winner_allowed": {
          "type": "boolean",
          "const": false
        },
        "scoped_recommendation_allowed": {
          "type": "boolean"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "required": [
        "subject_ref",
        "subject_kind",
        "subject_label",
        "subject_status",
        "limitations"
      ],
      "properties": {
        "subject_ref": {
          "type": "string"
        },
        "subject_kind": {
          "type": "string",
          "enum": [
            "object_page",
            "source_page",
            "public_search_result",
            "public_index_document",
            "source_cache_record",
            "evidence_ledger_record",
            "candidate_index_record",
            "known_absence_page",
            "synthetic_example",
            "unknown"
          ]
        },
        "subject_label": {
          "type": "string"
        },
        "subject_status": {
          "type": "string",
          "enum": [
            "fixture_backed",
            "recorded_fixture_backed",
            "candidate",
            "review_required",
            "placeholder",
            "future",
            "conflicted",
            "unknown"
          ]
        },
        "object_kind": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "representation_kind": {
          "type": "string"
        },
        "evidence_status": {
          "type": "string"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "criterion": {
      "type": "object",
      "required": [
        "criterion_id",
        "criterion_type",
        "criterion_label",
        "required",
        "scoring_policy",
        "evidence_required",
        "limitations"
      ],
      "properties": {
        "criterion_id": {
          "type": "string"
        },
        "criterion_type": {
          "type": "string",
          "enum": [
            "identity_match",
            "version_match",
            "platform_compatibility",
            "architecture_compatibility",
            "source_coverage",
            "evidence_strength",
            "provenance_quality",
            "representation_availability",
            "member_access",
            "rights_access",
            "risk_posture",
            "actionability",
            "conflict_status",
            "absence_scope",
            "user_cost",
            "unknown"
          ]
        },
        "criterion_label": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "scoring_policy": {
          "type": "string",
          "enum": [
            "descriptive_only",
            "categorical",
            "future_weighted",
            "not_scored"
          ]
        },
        "evidence_required": {
          "type": "boolean"
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "comparison_matrix": {
      "type": "object"
    },
    "comparison_cell": {
      "type": "object"
    },
    "identity_comparison": {
      "type": "object"
    },
    "version_state_release_comparison": {
      "type": "object"
    },
    "representation_member_comparison": {
      "type": "object"
    },
    "source_evidence_provenance_comparison": {
      "type": "object"
    },
    "compatibility_comparison": {
      "type": "object"
    },
    "rights_risk_action_comparison": {
      "type": "object"
    },
    "conflicts_and_disagreements": {
      "type": "object"
    },
    "absence_near_miss_gap_comparison": {
      "type": "object"
    },
    "result_card_object_source_projection": {
      "type": "object"
    },
    "api_projection": {
      "type": "object"
    },
    "static_projection": {
      "type": "object"
    },
    "privacy": {
      "type": "object"
    }
  },
  "x-status": "contract_only",
  "x-runtime_comparison_page_implemented": false,
  "x-persistent_comparison_page_store_implemented": false,
  "x-live_source_calls_allowed": false,
  "x-downloads_enabled": false,
  "x-installs_enabled": false,
  "x-execution_enabled": false,
  "x-winner_claims_allowed_without_evidence": false,
  "x-source_sync_worker_execution_allowed": false,
  "x-source_cache_mutation_allowed": false,
  "x-evidence_ledger_mutation_allowed": false,
  "x-candidate_index_mutation_allowed": false,
  "x-candidate_promotion_allowed": false,
  "x-public_index_mutation_allowed": false,
  "x-local_index_mutation_allowed": false,
  "x-master_index_mutation_allowed": false,
  "x-telemetry_implemented": false
}
