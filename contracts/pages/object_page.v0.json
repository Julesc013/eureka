        },
        "known_absence_page_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checked_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_checked_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gap": {
      "type": "object",
      "required": [
        "gap_type",
        "explanation",
        "future_next_step",
        "limitations"
      ],
      "properties": {
