{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/pages/object_page.v0.json",
  "title": "EurekaObjectPageV0",
  "description": "Contract-only, evidence-first public object page shape. It defines future page payloads without implementing runtime object pages, downloads, installs, execution, live source fanout, or index/cache/ledger mutation.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "object_page_id",
    "object_page_kind",
    "status",
    "created_by_tool",
    "object_identity",
    "object_status",
    "title",
    "summary",
    "versions_states_releases",
    "representations",
    "members",
    "sources",
    "evidence",
    "compatibility",
    "rights_risk_action_posture",
    "conflicts",
    "absence_near_misses_gaps",
    "result_card_projection",
    "api_projection",
    "static_projection",
    "privacy",
    "limitations",
    "no_runtime_guarantees",
    "no_mutation_guarantees",
    "notes",
    "runtime_object_page_implemented",
    "persistent_object_page_store_implemented",
    "object_page_generated_from_live_source",
    "live_source_called",
    "external_calls_performed",
    "source_cache_mutated",
    "evidence_ledger_mutated",
    "candidate_index_mutated",
    "candidate_promotion_performed",
    "public_index_mutated",
    "local_index_mutated",
    "master_index_mutated",
    "downloads_enabled",
    "uploads_enabled",
    "installs_enabled",
    "execution_enabled",
    "arbitrary_url_fetch_enabled",
    "rights_clearance_claimed",
    "malware_safety_claimed",
    "telemetry_exported"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "object_page_id": {
      "type": "string",
      "minLength": 1
    },
    "object_page_kind": {
      "type": "string",
      "const": "object_page"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft_example",
        "dry_run_validated",
        "synthetic_example",
        "public_safe_example",
        "candidate_only",
        "review_required",
        "runtime_future",
        "rejected_by_policy"
      ]
    },
    "created_by_tool": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "object_identity": {
      "$ref": "#/$defs/object_identity"
    },
    "object_status": {
      "$ref": "#/$defs/object_status"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "versions_states_releases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/version_state_release"
      }
    },
    "representations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/representation"
      }
    },
    "members": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/member"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "rights_risk_action_posture": {
      "$ref": "#/$defs/rights_risk_action_posture"
    },
    "conflicts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflict"
      }
    },
    "absence_near_misses_gaps": {
      "$ref": "#/$defs/absence_near_misses_gaps"
    },
    "result_card_projection": {
      "$ref": "#/$defs/result_card_projection"
    },
    "api_projection": {
      "$ref": "#/$defs/api_projection"
    },
    "static_projection": {
      "$ref": "#/$defs/static_projection"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "no_runtime_guarantees": {
      "type": "object"
    },
    "no_mutation_guarantees": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_object_page_implemented": {
      "type": "boolean",
      "const": false
    },
    "persistent_object_page_store_implemented": {
      "type": "boolean",
      "const": false
    },
    "object_page_generated_from_live_source": {
      "type": "boolean",
      "const": false
    },
    "live_source_called": {
      "type": "boolean",
      "const": false
    },
    "external_calls_performed": {
      "type": "boolean",
      "const": false
    },
    "source_cache_mutated": {
      "type": "boolean",
      "const": false
    },
    "evidence_ledger_mutated": {
      "type": "boolean",
      "const": false
    },
    "candidate_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "candidate_promotion_performed": {
      "type": "boolean",
      "const": false
    },
    "public_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "local_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "master_index_mutated": {
      "type": "boolean",
      "const": false
    },
    "downloads_enabled": {
      "type": "boolean",
      "const": false
    },
    "uploads_enabled": {
      "type": "boolean",
      "const": false
    },
    "installs_enabled": {
      "type": "boolean",
      "const": false
    },
    "execution_enabled": {
      "type": "boolean",
      "const": false
    },
    "arbitrary_url_fetch_enabled": {
      "type": "boolean",
      "const": false
    },
    "rights_clearance_claimed": {
      "type": "boolean",
      "const": false
    },
    "malware_safety_claimed": {
      "type": "boolean",
      "const": false
    },
    "telemetry_exported": {
      "type": "boolean",
      "const": false
    }
  },
  "$defs": {
    "object_identity": {
      "type": "object",
      "required": [
        "object_id",
        "object_kind",
        "canonical_label",
        "aliases",
        "identifiers",
        "identity_confidence",
        "identity_status",
        "identity_not_truth",
        "limitations"
      ],
      "properties": {
        "object_id": {
          "type": "string"
        },
        "object_kind": {
          "type": "string",
          "enum": [
            "software",
            "software_version",
            "driver",
            "manual_or_documentation",
            "source_code_release",
            "package_metadata",
            "web_capture",
            "article_or_scan_segment",
            "file_inside_container",
            "compatibility_evidence",
            "source_identity",
            "collection",
            "unknown"
          ]
        },
        "canonical_label": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "product_name": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string"
        },
        "identifiers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "parent_object_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "child_object_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "identity_confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "identity_status": {
          "type": "string",
          "enum": [
            "accepted_fixture",
            "candidate",
            "review_required",
            "conflicted",
            "unknown"
          ]
        },
        "identity_not_truth": {
          "type": "boolean",
          "const": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "object_status": {
      "type": "object",
      "required": [
        "page_lane",
        "verification_status",
        "public_visibility",
        "actionability_status",
        "limitations"
      ],
      "properties": {
        "page_lane": {
          "type": "string",
          "enum": [
            "official",
            "preservation",
            "community",
            "candidate",
            "absence",
            "conflicted",
            "demo",
            "unknown"
          ]
        },
        "verification_status": {
          "type": "string",
          "enum": [
            "fixture_backed",
            "evidence_backed",
            "candidate_only",
            "review_required",
            "insufficient_evidence",
            "conflicted",
            "synthetic_example"
          ]
        },
        "public_visibility": {
          "type": "string",
          "enum": [
            "public_safe_example",
            "public_safe_future",
            "local_private",
            "restricted"
          ]
        },
        "actionability_status": {
          "type": "string",
          "enum": [
            "inspect_only",
            "cite_only",
            "compare_only",
            "future_action_required",
            "no_safe_action"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "version_state_release": {
      "type": "object",
      "required": [
        "state_ref",
        "label",
        "version",
        "source_refs",
        "evidence_refs",
        "confidence",
        "limitations"
      ],
      "properties": {
        "state_ref": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "release_date": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        },
        "lifecycle_status": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "representation": {
      "type": "object",
      "required": [
        "representation_ref",
        "representation_kind",
        "label",
        "source_refs",
        "evidence_refs",
        "access_status",
        "payload_included",
        "downloads_enabled",
        "limitations"
      ],
      "properties": {
        "representation_ref": {
          "type": "string"
        },
        "representation_kind": {
          "type": "string",
          "enum": [
            "file",
            "archive",
            "installer",
            "ISO",
            "source_archive",
            "package",
            "web_capture",
            "scan",
            "article_segment",
            "metadata_record",
            "unknown"
          ]
        },
        "label": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "checksum_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "size_summary": {
          "type": "string"
        },
        "access_status": {
          "type": "string",
          "enum": [
            "metadata_only",
            "available_source_unknown",
            "access_restricted",
            "unavailable",
            "future",
            "unknown"
          ]
        },
        "payload_included": {
          "type": "boolean",
          "const": false
        },
        "downloads_enabled": {
          "type": "boolean",
          "const": false
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "member": {
      "type": "object",
      "required": [
        "member_ref",
        "parent_representation_ref",
        "member_kind",
        "label",
        "source_refs",
        "evidence_refs",
        "synthetic_or_observed",
        "limitations"
      ],
      "properties": {
        "member_ref": {
          "type": "string"
        },
        "parent_representation_ref": {
          "type": "string"
        },
        "member_kind": {
          "type": "string",
          "enum": [
            "file",
            "directory",
            "article",
            "manifest",
            "installer_member",
            "archive_member",
            "scan_region",
            "unknown"
          ]
        },
        "member_path_public_safe": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "synthetic_or_observed": {
          "type": "string",
          "enum": [
            "synthetic_example",
            "fixture_observed",
            "evidence_candidate",
            "future_extraction"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "required": [
        "source_id",
        "source_family",
        "source_status",
        "source_role",
        "limitations"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "source_status": {
          "type": "string",
          "enum": [
            "active_fixture",
            "active_recorded_fixture",
            "placeholder",
            "future",
            "approval_required",
            "disabled",
            "unknown"
          ]
        },
        "source_role": {
          "type": "string",
          "enum": [
            "primary",
            "supporting",
            "conflicting",
            "near_miss",
            "not_checked"
          ]
        },
        "source_cache_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "evidence_ref",
        "evidence_kind",
        "evidence_status",
        "claim_summary",
        "provenance_refs",
        "confidence",
        "confidence_not_truth",
        "limitations"
      ],
      "properties": {
        "evidence_ref": {
          "type": "string"
        },
        "evidence_kind": {
          "type": "string"
        },
        "evidence_status": {
          "type": "string",
          "enum": [
            "fixture",
            "recorded_fixture",
            "source_cache_future",
            "evidence_ledger_future",
            "candidate",
            "review_required",
            "insufficient"
          ]
        },
        "claim_summary": {
          "type": "string"
        },
        "provenance_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "confidence_not_truth": {
          "type": "boolean",
          "const": true
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "required": [
        "compatibility_status",
        "platform_refs",
        "operating_systems",
        "architectures",
        "runtime_requirements",
        "source_refs",
        "evidence_refs",
        "confidence",
        "limitations"
      ],
      "properties": {
        "compatibility_status": {
          "type": "string",
          "enum": [
            "known_supported",
            "likely_supported",
            "unknown",
            "likely_unsupported",
            "conflicting",
            "evidence_required"
          ]
        },
        "platform_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operating_systems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "architectures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtime_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "rights_risk_action_posture": {
      "type": "object",
      "required": [
        "rights_classification",
        "risk_classification",
        "allowed_actions",
        "disabled_actions",
        "downloads_enabled",
        "installs_enabled",
        "execution_enabled",
        "uploads_enabled",
        "mirroring_enabled",
        "arbitrary_url_fetch_enabled",
        "rights_clearance_claimed",
        "malware_safety_claimed",
        "limitations"
      ],
      "properties": {
        "rights_classification": {
          "type": "string",
          "enum": [
            "public_metadata_only",
            "source_terms_apply",
            "review_required",
            "restricted",
            "unknown"
          ]
        },
        "risk_classification": {
          "type": "string",
          "enum": [
            "metadata_only",
            "executable_reference",
            "private_data_risk",
            "credential_risk",
            "malware_review_required",
            "unknown"
          ]
        },
        "allowed_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "inspect_metadata",
              "view_sources",
              "view_evidence",
              "compare",
              "cite"
            ]
          }
        },
        "disabled_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "download",
              "install",
              "execute",
              "upload",
              "mirror",
              "arbitrary_url_fetch"
            ]
          }
        },
        "downloads_enabled": {
          "type": "boolean",
          "const": false
        },
        "installs_enabled": {
          "type": "boolean",
          "const": false
        },
        "execution_enabled": {
          "type": "boolean",
          "const": false
        },
        "uploads_enabled": {
          "type": "boolean",
          "const": false
        },
        "mirroring_enabled": {
          "type": "boolean",
          "const": false
        },
        "arbitrary_url_fetch_enabled": {
          "type": "boolean",
          "const": false
        },
        "rights_clearance_claimed": {
          "type": "boolean",
          "const": false
        },
        "malware_safety_claimed": {
          "type": "boolean",
          "const": false
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conflict": {
      "type": "object",
      "required": [
        "conflict_id",
        "conflict_type",
        "summary",
        "conflicting_refs",
        "resolution_status",
        "destructive_merge_allowed",
        "limitations"
      ],
      "properties": {
        "conflict_id": {
          "type": "string"
        },
        "conflict_type": {
          "type": "string",
          "enum": [
            "identity_conflict",
            "version_conflict",
            "source_conflict",
            "compatibility_conflict",
            "evidence_conflict",
            "rights_or_access_conflict",
            "duplicate_candidate",
            "unknown"
          ]
        },
        "summary": {
          "type": "string"
        },
        "conflicting_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "unresolved",
            "review_required",
            "preserved_conflict",
            "resolved_future"
          ]
        },
        "destructive_merge_allowed": {
          "type": "boolean",
          "const": false
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "absence_near_misses_gaps": {
      "type": "object",
      "required": [
        "absence_status",
        "global_absence_claimed",
        "near_misses",
        "gaps",
        "known_absence_page_refs",
        "checked_scope",
        "not_checked_scope",
        "limitations"
      ],
      "properties": {
        "absence_status": {
          "type": "string",
          "enum": [
            "not_absent",
            "scoped_absence",
            "no_verified_result",
            "unknown"
          ]
        },
        "global_absence_claimed": {
          "type": "boolean",
          "const": false
        },
        "near_misses": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
