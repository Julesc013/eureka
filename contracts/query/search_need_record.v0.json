        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suggested_next_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/next_step"
