        "representative_platforms",
        "representative_artifact_types",
        "confidence",
        "demand_classification"
      ],
      "properties": {
        "occurrence_count": {
          "type": "integer",
          "minimum": 0
        },
        "distinct_query_fingerprint_count": {
          "type": "integer",
          "minimum": 0
        },
        "distinct_normalized_need_count": {
          "type": "integer",
          "minimum": 0
        },
        "first_seen_policy": {
          "type": "string",
          "enum": [
            "not_tracked_in_v0_example",
            "future_local_private",
            "future_public_aggregate"
          ]
        },
        "last_seen_policy": {
          "type": "string",
          "enum": [
            "not_tracked_in_v0_example",
            "future_local_private",
            "future_public_aggregate"
          ]
        },
        "representative_intents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "representative_platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "representative_artifact_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "demand_classification": {
          "type": "string",
          "enum": [
            "single_example",
            "repeated_future",
            "high_demand_future",
            "unknown"
          ]
        }
      }
    },
    "source_and_capability_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_gap"
      }
    },
    "checked_scope": {
