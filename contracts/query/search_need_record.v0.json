{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/query/search_need_record.v0.json",
  "title": "EurekaSearchNeedRecordV0",
  "description": "Search need record contract for future aggregation of privacy-filtered misses, weak hits, near misses, and unresolved intents. P62 is contract/example/validation only and adds no persistent search need store, telemetry, runtime need creation, probe queue, candidate index, demand dashboard, or master-index mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "search_need_id",
    "search_need_kind",
    "status",
    "created_by_tool",
    "need_identity",
    "target_object",
    "originating_inputs",
    "aggregate_summary",
    "source_and_capability_gaps",
    "checked_scope",
    "not_checked_scope",
    "evidence_and_result_context",
    "suggested_next_steps",
    "priority",
    "privacy",
    "retention_policy",
    "aggregation_policy",
    "limitations",
    "no_mutation_guarantees",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "search_need_id": {
      "type": "string",
      "minLength": 1
    },
    "search_need_kind": {
      "type": "string",
      "const": "search_need_record"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft_example",
        "dry_run_validated",
        "unresolved",
        "local_private",
        "public_aggregate_candidate",
        "rejected_by_privacy_filter",
        "merged_future",
        "superseded_future",
        "resolved_future"
      ]
    },
    "created_by_tool": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "description": "Optional future timestamp. Examples should avoid volatile required timestamps."
    },
    "updated_at": {
      "type": "string",
      "description": "Optional future timestamp. Examples should avoid volatile required timestamps."
    },
    "need_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "need_fingerprint",
        "canonical_need_label",
        "normalized_need_terms",
        "disambiguation_terms",
        "equivalence_keys",
        "alias_terms"
      ],
      "properties": {
        "need_fingerprint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "normalized_basis",
            "value",
            "reversible",
            "salt_policy"
          ],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": [
                "sha256"
              ]
            },
            "normalized_basis": {
              "type": "string"
            },
            "value": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "reversible": {
              "type": "boolean",
              "const": false
            },
            "salt_policy": {
              "type": "string",
              "enum": [
                "unsalted_public_aggregate",
                "deployment_secret_salted_future",
                "local_private_salted_future"
              ]
            }
          }
        },
        "canonical_need_label": {
          "type": "string",
          "minLength": 1
        },
        "normalized_need_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "disambiguation_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "equivalence_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alias_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "duplicate_of": {
          "type": "string"
        },
        "merged_from": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "target_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_kind",
        "desired_action"
      ],
      "properties": {
        "object_kind": {
          "type": "string",
          "enum": [
            "software",
            "software_version",
            "driver",
            "manual_or_documentation",
            "source_code_release",
            "package_metadata",
            "web_capture",
            "article_or_scan_segment",
            "file_inside_container",
            "compatibility_evidence",
            "source_identity",
            "unknown"
          ]
        },
        "product_name": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "architecture": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "date_or_period": {
          "type": "string"
        },
        "identifiers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compatibility_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "desired_action": {
          "type": "string",
          "enum": [
            "inspect",
            "compare",
            "cite",
            "preserve",
            "locate_download_disabled",
            "install_intent_detected_but_disabled",
            "emulate_intent_detected_but_disabled",
            "unknown"
          ]
        }
      }
    },
    "originating_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_observation_refs",
        "search_miss_ledger_refs",
        "search_result_cache_refs"
