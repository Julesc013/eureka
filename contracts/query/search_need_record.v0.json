        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    },
    "retention_policy": {
      "$ref": "#/$defs/retention_policy"
