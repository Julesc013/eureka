      "properties": {
        "query_observation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "search_miss_ledger_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "search_result_cache_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "manual_observation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "source_pack_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "evidence_pack_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        }
      }
    },
    "aggregate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "occurrence_count",
        "distinct_query_fingerprint_count",
        "distinct_normalized_need_count",
        "first_seen_policy",
        "last_seen_policy",
