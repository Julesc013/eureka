        "priority_basis": {
          "type": "string",
          "enum": [
            "single_need_example",
            "repeated_need_future",
            "high_gap_future",
            "manual_priority_future",
            "source_policy_priority_future",
            "safety_priority_future",
            "unknown"
          ]
        },
        "demand_count_claimed": {
          "type": "boolean",
          "const": false
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
