{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/query/probe_queue_item.v0.json",
  "title": "EurekaProbeQueueItemV0",
  "description": "Probe Queue v0 contract for future, reviewable probe planning items derived from privacy-filtered search needs. P63 is contract/example/validation only and adds no runtime probe queue, persistence, probe execution, source cache runtime, evidence ledger runtime, candidate index runtime, telemetry, external calls, live probes, or master-index mutation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "probe_item_id",
    "probe_item_kind",
    "status",
    "created_by_tool",
    "probe_identity",
    "probe_kind",
    "source_policy",
    "input_refs",
    "target",
    "priority",
    "scheduling",
    "expected_outputs",
    "safety_requirements",
    "privacy",
    "retention_policy",
    "aggregation_policy",
    "limitations",
    "no_execution_guarantees",
    "no_mutation_guarantees",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "probe_item_id": {
      "type": "string",
      "minLength": 1
    },
    "probe_item_kind": {
      "type": "string",
      "const": "probe_queue_item"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft_example",
        "dry_run_validated",
        "queued_future",
        "local_private",
        "public_aggregate_candidate",
        "rejected_by_privacy_filter",
        "approval_required",
        "operator_required",
        "blocked_by_policy",
        "superseded_future",
        "completed_future",
        "cancelled_future"
      ]
    },
    "created_by_tool": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "description": "Optional future timestamp. Examples should avoid volatile required timestamps."
    },
    "updated_at": {
      "type": "string",
      "description": "Optional future timestamp. Examples should avoid volatile required timestamps."
    },
    "probe_identity": {
      "$ref": "#/$defs/probe_identity"
    },
    "probe_kind": {
      "$ref": "#/$defs/probe_kind"
    },
    "source_policy": {
      "$ref": "#/$defs/source_policy"
    },
    "input_refs": {
      "$ref": "#/$defs/input_refs"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "priority": {
      "$ref": "#/$defs/priority"
    },
    "scheduling": {
      "$ref": "#/$defs/scheduling"
    },
    "expected_outputs": {
      "$ref": "#/$defs/expected_outputs"
    },
    "safety_requirements": {
      "$ref": "#/$defs/safety_requirements"
    },
    "privacy": {
      "$ref": "#/$defs/privacy"
    },
    "retention_policy": {
      "$ref": "#/$defs/retention_policy"
    },
    "aggregation_policy": {
      "$ref": "#/$defs/aggregation_policy"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "no_execution_guarantees": {
      "$ref": "#/$defs/no_execution_guarantees"
    },
    "no_mutation_guarantees": {
      "$ref": "#/$defs/no_mutation_guarantees"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "probe_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probe_fingerprint",
        "canonical_probe_label",
        "normalized_probe_terms"
      ],
      "properties": {
        "probe_fingerprint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "algorithm",
            "normalized_basis",
            "value",
            "reversible",
            "salt_policy"
          ],
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": [
                "sha256"
              ]
            },
            "normalized_basis": {
              "type": "string"
            },
            "value": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "reversible": {
              "type": "boolean",
              "const": false
            },
            "salt_policy": {
              "type": "string",
              "enum": [
                "unsalted_public_aggregate",
                "deployment_secret_salted_future",
                "local_private_salted_future"
              ]
            }
          }
        },
        "canonical_probe_label": {
          "type": "string",
          "minLength": 1
        },
        "normalized_probe_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "duplicate_of": {
          "type": "string"
        },
        "supersedes": {
          "type": "string"
        }
      }
    },
    "probe_kind": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "execution_class",
        "live_network_required_future",
        "approval_required",
        "operator_required",
        "human_required"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "manual_observation",
            "source_cache_refresh",
            "source_metadata_probe",
            "source_identifier_probe",
            "wayback_availability_probe",
            "package_metadata_probe",
            "repository_release_probe",
            "deep_container_extraction",
            "member_enumeration",
            "OCR_or_scan_extraction",
            "compatibility_evidence_request",
            "source_pack_request",
            "evidence_pack_request",
            "index_pack_request",
            "query_parser_improvement_request",
            "unknown"
          ]
        },
        "execution_class": {
          "type": "string",
          "enum": [
            "human_operated_future",
            "scheduled_worker_future",
            "approval_gated_live_probe_future",
            "local_offline_extraction_future",
            "connector_runtime_future",
            "no_execution_v0"
          ]
        },
        "live_network_required_future": {
          "type": "boolean"
        },
        "approval_required": {
          "type": "boolean"
        },
        "operator_required": {
          "type": "boolean"
        },
        "human_required": {
          "type": "boolean"
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_policy_kind",
        "allowed_source_ids",
        "allowed_source_families",
        "prohibited_source_families",
        "live_probe_enabled",
        "source_terms_review_required",
        "rights_review_required",
        "notes"
      ],
      "properties": {
        "source_policy_kind": {
          "type": "string",
          "enum": [
            "no_source_call",
            "manual_only",
            "fixture_only",
            "source_cache_only_future",
            "live_metadata_probe_after_approval",
            "local_offline_extraction_after_approval",
            "unknown"
          ]
        },
        "allowed_source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_source_families": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "prohibited_source_families": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "live_probe_enabled": {
          "type": "boolean",
          "const": false
        },
        "source_rate_limit_policy_ref": {
          "type": "string"
        },
        "source_terms_review_required": {
          "type": "boolean"
        },
        "rights_review_required": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_observation_refs",
        "search_result_cache_refs",
        "search_miss_ledger_refs",
