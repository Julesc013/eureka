        "search_miss_ledger_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "search_need_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "manual_observation_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "source_pack_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        },
        "evidence_pack_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input_ref"
          }
        }
      }
    },
    "input_ref": {
      "type": "object",
