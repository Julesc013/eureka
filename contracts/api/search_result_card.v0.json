{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/api/search_result_card.v0.json",
  "title": "EurekaPublicSearchResultCardV0",
  "description": "Contract-only public search result card for future web, API, lite/text, native, relay, snapshot, and contribution consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract_id",
    "stability",
    "result_id",
    "title",
    "record_kind",
    "result_lane",
    "user_cost",
    "source",
    "identity",
    "evidence",
    "compatibility",
    "actions",
    "rights",
    "risk",
    "warnings",
    "limitations",
    "gaps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "contract_id": {
      "type": "string",
      "const": "eureka_public_search_result_card_v0"
    },
    "stability": {
      "$ref": "#/$defs/stability"
    },
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_kind": {
      "type": "string",
      "minLength": 1
    },
    "matched_query_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "why_matched": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "why_ranked": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "x-stability": "experimental"
    },
    "result_lane": {
      "type": "string",
      "enum": [
        "best_direct_answer",
        "installable_or_usable_now",
        "inside_bundles",
        "official",
        "preservation",
        "community",
        "documentation",
        "mentions_or_traces",
        "absence_or_next_steps",
        "still_searching",
        "other"
      ]
    },
    "user_cost": {
      "$ref": "#/$defs/user_cost"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "evidence": {
      "$ref": "#/$defs/evidence"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "parent_lineage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lineage_item"
      }
    },
    "member": {
      "anyOf": [
        {
          "$ref": "#/$defs/member"
        },
        {
          "type": "null"
        }
      ]
    },
    "representation": {
      "anyOf": [
        {
          "$ref": "#/$defs/representation"
        },
        {
          "type": "null"
        }
      ]
    },
    "temporal": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "date_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "state_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "ordering_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "$ref": "#/$defs/actions"
    },
    "rights": {
      "$ref": "#/$defs/rights"
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fixture_backed",
          "source_coverage_limited",
          "compatibility_evidence_limited",
          "no_live_probe",
          "no_download",
          "no_install",
          "no_execute",
          "no_upload",
          "no_malware_scan",
          "no_rights_clearance",
          "external_baseline_pending",
          "static_summary_only",
          "local_index_only",
          "not_production_ranking"
        ]
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inspect": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "type": [
            "string",
            "null"
          ]
        },
        "absence": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "description": "Base-path-safe public links only. Values must not be private paths, download URLs, or install URLs."
    },
    "debug": {
      "type": [
        "object",
        "null"
      ],
      "description": "Experimental diagnostic block disabled by default in future public runtimes.",
      "x-stability": "future"
    }
  },
  "$defs": {
    "stability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_draft",
        "experimental",
        "volatile",
        "internal",
        "future"
      ],
      "properties": {
        "stable_draft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "experimental": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "volatile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "internal": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "future": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "user_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "label",
        "reasons",
        "explanation"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "label": {
          "type": "string",
          "enum": [
            "very_low",
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explanation": {
          "type": "string"
        }
      },
      "description": "Lower score means lower user detective work. This is a bounded deterministic hint, not production ranking."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_family",
        "source_status",
        "coverage_depth",
        "checked_as",
        "limitations"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "source_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_status": {
          "type": "string"
        },
        "posture": {
          "type": [
            "string",
            "null"
          ]
        },
        "coverage_depth": {
          "type": "string"
        },
        "trust_lane": {
          "type": [
            "string",
            "null"
          ],
          "x-stability": "experimental"
        },
        "source_lane": {
          "type": [
            "string",
            "null"
          ],
          "x-stability": "experimental"
        },
        "checked_as": {
          "type": "string",
          "enum": [
            "local_index",
            "recorded_fixture",
            "static_summary",
            "future_live_probe",
            "not_checked"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "public_target_ref",
        "identity_status",
        "notes"
      ],
      "properties": {
        "public_target_ref": {
          "type": "string"
        },
        "target_ref": {
          "type": [
            "string",
            "null"
          ],
          "description": "Compatibility alias allowed only when it is public-safe."
        },
        "resolved_resource_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "object_id": {
          "type": [
            "string",
            "null"
          ],
          "x-stability": "future"
        },
        "release_or_state_id": {
          "type": [
            "string",
            "null"
          ],
          "x-stability": "future"
        },
        "representation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "member_target_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "native_source_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "identity_status": {
          "type": "string",
          "enum": [
            "exact",
            "candidate",
            "ambiguous",
            "unresolved",
            "synthetic_member",
            "article_segment",
            "unknown"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_count",
        "summaries",
        "provenance_notes",
        "missing_evidence"
      ],
      "properties": {
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_summary"
          }
        },
        "provenance_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Public-safe summaries only. Raw source payloads are not included by default."
    },
    "evidence_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_kind",
        "source_id"
      ],
      "properties": {
        "evidence_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_kind": {
          "type": "string"
        },
        "source_id": {
          "type": "string"
        },
        "locator": {
          "type": [
            "string",
            "null"
          ]
        },
        "snippet": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 280
        },
        "confidence": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "high",
            "medium",
            "low",
            "unknown",
            null
          ],
          "x-stability": "experimental"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "target_platforms",
        "architecture",
        "evidence_summaries",
        "confidence",
        "caveats",
        "unknowns"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "supported",
            "unsupported",
            "unknown",
            "partial",
            "candidate",
            "not_applicable"
          ]
        },
        "target_platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "architecture": {
          "type": "string"
        },
        "evidence_summaries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_summary"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ],
          "x-stability": "experimental"
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unknowns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Compatibility evidence is bounded and must not claim universal compatibility."
    },
    "lineage_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_ref",
        "label",
        "relationship"
      ],
      "properties": {
        "target_ref": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "relationship": {
          "type": "string"
        }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "member_path",
        "member_label",
        "member_kind",
        "media_type",
        "parent_target_ref",
        "parent_label",
        "parent_lineage"
      ],
      "properties": {
        "member_path": {
          "type": "string"
        },
        "member_label": {
          "type": "string"
        },
        "member_kind": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "byte_length": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "parent_target_ref": {
          "type": "string"
        },
        "parent_label": {
          "type": "string"
        },
        "parent_lineage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lineage_item"
          }
        }
      }
    },
    "representation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "representation_id",
        "representation_kind",
        "media_type",
        "limitations"
      ],
      "properties": {
        "representation_id": {
          "type": "string"
        },
        "representation_kind": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "file_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "size": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "checksum": {
          "type": [
            "string",
            "null"
          ]
        },
        "access_path_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "blocked",
        "future_gated"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_entry"
          }
        },
        "blocked": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_entry"
          }
        },
        "future_gated": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_entry"
          }
        }
      }
    },
    "action_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "status",
        "reason"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "enum": [
            "inspect",
            "preview",
            "read",
            "cite",
            "export_manifest",
            "view_provenance",
            "compare",
            "view_source",
            "view_absence_report",
            "download",
            "download_member",
            "mirror",
            "install_handoff",
            "package_manager_handoff",
            "emulator_handoff",
            "vm_handoff",
            "execute",
            "restore_apply",
            "uninstall",
            "rollback",
            "upload",
            "submit_private_source",
            "live_probe"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "allowed",
            "blocked",
            "future_gated",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string"
        },
        "policy_reference": {
          "type": [
            "string",
            "null"
          ]
        },
        "requires_confirmation": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "requires_future_policy": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rights_status",
        "distribution_allowed",
        "notes"
      ],
      "properties": {
        "rights_status": {
          "type": "string",
          "enum": [
            "unknown",
            "public_metadata_only",
            "source_terms_apply",
            "restricted",
            "review_required",
            "not_applicable"
          ]
        },
        "distribution_allowed": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unknown"
          ]
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Unknown is not clearance. This block must not claim rights clearance."
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable_risk",
        "malware_scan_status",
        "warnings"
      ],
      "properties": {
        "executable_risk": {
          "type": "string",
          "enum": [
            "none",
            "metadata_only",
            "executable_unknown",
            "executable_present",
            "not_applicable"
          ]
        },
        "malware_scan_status": {
          "type": "string",
          "enum": [
            "not_scanned",
            "unavailable",
            "future",
            "not_applicable"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      },
      "description": "No malware safety or executable trust claim exists in v0."
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_type",
        "message",
        "severity"
      ],
      "properties": {
        "warning_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "caution",
            "warning",
            "blocked"
          ]
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_type",
        "message"
      ],
      "properties": {
        "gap_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "x-contract_id": "eureka_public_search_result_card_v0",
  "x-created_by_slice": "public_search_result_card_contract_v0",
  "x-status": "contract_only",
  "x-related_contracts": [
    "contracts/api/search_response.v0.json",
    "docs/reference/PUBLIC_SEARCH_API_CONTRACT.md",
    "docs/reference/ACTION_DOWNLOAD_INSTALL_POLICY.md",
    "docs/reference/EXECUTABLE_RISK_POLICY.md",
    "docs/reference/RIGHTS_AND_ACCESS_POLICY.md",
    "docs/reference/SNAPSHOT_CONSUMER_CONTRACT.md",
    "docs/reference/NATIVE_CLIENT_CONTRACT.md",
    "docs/reference/RELAY_SURFACE_CONTRACT.md"
  ],
  "x-default_allowed_actions": [
    "inspect",
    "preview",
    "read",
    "cite",
    "export_manifest",
    "view_provenance",
    "compare",
    "view_source",
    "view_absence_report"
  ],
  "x-blocked_or_future_gated_actions": [
    "download",
    "download_member",
    "mirror",
    "install_handoff",
    "package_manager_handoff",
    "emulator_handoff",
    "vm_handoff",
    "execute",
    "restore_apply",
    "uninstall",
    "rollback",
    "upload",
    "submit_private_source",
    "live_probe"
  ],
  "x-forbidden_fields": [
    "private_local_path",
    "raw_source_payload",
    "source_credentials",
    "download_url",
    "install_url",
    "execute_url",
    "malware_safe",
    "rights_cleared"
  ],
  "x-forbidden_claims": [
    "malware safety",
    "rights clearance",
    "production ranking",
    "live hosted search"
  ]
}
