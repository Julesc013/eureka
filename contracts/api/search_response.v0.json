{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eureka.local/contracts/api/search_response.v0.json",
  "title": "EurekaPublicSearchResponseV0",
  "description": "Contract-only successful response envelope for future local-index-only public search.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "schema_version",
    "contract_id",
    "mode",
    "query",
    "limits",
    "results",
    "checked_sources",
    "gaps",
    "warnings",
    "generated_by",
    "stability"
  ],
  "properties": {
    "ok": {
      "const": true
    },
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "contract_id": {
      "type": "string",
      "const": "eureka_public_search_response_v0"
    },
    "mode": {
      "type": "string",
      "const": "local_index_only"
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw",
        "normalized",
        "notices"
      ],
      "properties": {
        "raw": {
          "type": "string",
          "maxLength": 160
        },
        "normalized": {
          "type": "string",
          "maxLength": 160
        },
        "interpreted_task_kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "notices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_limit",
        "query_length_limit"
      ],
      "properties": {
        "result_limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 25
        },
        "query_length_limit": {
          "type": "integer",
          "const": 160
        }
      }
    },
    "results": {
      "description": "Each entry is a public search result card aligned with contracts/api/search_result_card.v0.json. Compact aliases remain for P26 clients.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "checked_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checked_source"
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gap"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "absence_summary": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "status",
        "message",
        "searched_scope"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "none",
            "bounded_absence",
            "insufficient_local_coverage"
          ]
        },
        "message": {
          "type": "string"
        },
        "searched_scope": {
          "type": "string"
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "generated_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component",
        "contract",
        "runtime_mode"
      ],
      "properties": {
        "component": {
          "type": "string"
        },
        "contract": {
          "type": "string",
          "const": "public_search_api_contract_v0"
        },
        "runtime_mode": {
          "type": "string",
          "const": "local_index_only"
        },
        "notices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_draft",
        "experimental",
        "volatile",
        "future"
      ],
      "properties": {
        "stable_draft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "experimental": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "volatile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "future": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional public links. Values must be base-path safe and must not expose private local paths."
    },
    "debug": {
      "type": [
        "object",
        "null"
      ],
      "description": "Experimental diagnostic block disabled by default in future public runtimes."
    }
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_id",
        "title",
        "record_kind",
        "source_id",
        "source_family",
        "public_target_ref",
        "result_lane",
        "user_cost",
        "compatibility",
        "evidence",
        "actions",
        "links",
        "limitations"
      ],
      "properties": {
        "result_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "record_kind": {
          "type": "string"
        },
        "matched_query_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "why_matched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "why_ranked": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Experimental ranking explanation, not a production ranking guarantee."
        },
        "source_id": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "source": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional full source block from the public search result-card contract."
        },
        "public_target_ref": {
          "type": "string",
          "description": "Public-safe target reference. Private local paths and raw source payload locators are forbidden."
        },
        "target_ref": {
          "type": [
            "string",
            "null"
          ],
          "description": "Optional compatibility alias for existing internal vocabulary. Future public clients should prefer public_target_ref."
        },
        "resolved_resource_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "identity": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional full identity block from the public search result-card contract."
        },
        "result_lane": {
          "type": "string",
          "enum": [
            "best_direct_answer",
            "installable_or_usable_now",
            "inside_bundles",
            "official",
            "preservation",
            "community",
            "documentation",
            "mentions_or_traces",
            "absence_or_next_steps",
            "still_searching",
            "other"
          ]
        },
        "user_cost": {
          "$ref": "#/$defs/user_cost"
        },
        "compatibility": {
          "$ref": "#/$defs/compatibility"
        },
        "evidence": {
          "$ref": "#/$defs/evidence"
        },
        "parent_lineage": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "member": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional smallest-actionable-unit member block."
        },
        "representation": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional public-safe representation block."
        },
        "actions": {
          "$ref": "#/$defs/actions"
        },
        "rights": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional rights caveat block; never a rights-clearance claim."
        },
        "risk": {
          "type": [
            "object",
            "null"
          ],
          "description": "Optional executable-risk caveat block; never a malware-safety claim."
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gap"
          }
        },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "inspect": {
              "type": [
                "string",
                "null"
              ]
            },
            "source": {
              "type": [
                "string",
                "null"
              ]
            },
            "evidence": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "user_cost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "label",
        "reasons"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "label": {
          "type": "string"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summaries"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "compatible",
            "incompatible",
            "unknown",
            "not_applicable"
          ]
        },
        "summaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summaries",
        "count"
      ],
      "properties": {
        "summaries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "blocked",
        "notes"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Read/inspect actions only for v0 unless a future action policy allows more."
        },
        "blocked": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Must include downloads, installs, uploads, local path access, and live probes when those are requested."
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "checked_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_family",
        "coverage_depth",
        "status",
        "checked_as",
        "limitations"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "source_family": {
          "type": "string"
        },
        "coverage_depth": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "posture": {
          "type": [
            "string",
            "null"
          ]
        },
        "checked_as": {
          "type": "string",
          "enum": [
            "local_index",
            "recorded_fixture",
            "static_summary",
            "not_checked"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_type",
        "message"
      ],
      "properties": {
        "gap_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "source_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_type",
        "message"
      ],
      "properties": {
        "warning_type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "x-contract_id": "eureka_public_search_response_v0",
  "x-created_by_slice": "public_search_api_contract_v0",
  "x-status": "contract_only",
  "x-result_card_schema": "contracts/api/search_result_card.v0.json",
  "x-results_are_public_search_result_cards": true,
  "x-prohibited_result_fields": [
    "download_url",
    "install_url",
    "private_local_path",
    "raw_source_payload",
    "executable_trust_claim",
    "rights_clearance_claim",
    "malware_scan_claim"
  ],
  "x-forbidden_behaviors": [
    "live_probe",
    "external_search",
    "arbitrary_url_fetch",
    "download",
    "install",
    "upload",
    "local_filesystem_ingestion"
  ],
  "x-field_stability": {
    "stable_draft": [
      "ok",
      "schema_version",
      "contract_id",
      "mode",
      "query.raw",
      "query.normalized",
      "limits.result_limit",
      "limits.query_length_limit",
      "results[].result_id",
      "results[].title",
      "results[].record_kind",
      "results[].source_id",
      "results[].source_family",
      "results[].source",
      "results[].public_target_ref",
      "results[].identity",
      "results[].result_lane",
      "results[].user_cost",
      "results[].compatibility",
      "results[].evidence",
      "results[].actions",
      "results[].rights",
      "results[].risk",
      "results[].warnings",
      "results[].limitations",
      "checked_sources[]",
      "gaps[]",
      "warnings[]"
    ],
    "experimental": [
      "results[].summary",
      "results[].matched_query_terms",
      "results[].why_matched",
      "results[].why_ranked",
      "results[].parent_lineage",
      "results[].member",
      "results[].representation",
      "results[].links",
      "links",
      "absence_summary"
    ],
    "volatile": [
      "generated_by",
      "query.notices"
    ],
    "future": [
      "debug"
    ]
  }
}
